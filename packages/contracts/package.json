{
  "name": "@sunday/contracts",
  "version": "0.4.1",
  "description": "Canonical cross-app wire contracts for the Sunday suite (types + Zod schemas).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardfossland/sunday-platform.git",
    "directory": "packages/contracts"
  },
  "homepage": "https://github.com/richardfossland/sunday-platform/tree/main/packages/contracts#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
