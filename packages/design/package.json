{
  "name": "@sunday/design",
  "version": "0.1.0",
  "description": "Sunday suite design tokens: shared palette/typography/spacing + per-app accent map (UI), plus the brand-identity layer (gold-cross thread + per-app icon jewel tones) from the Brand Sheet, with a Tailwind v4 @theme stylesheet.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": [
    "dist",
    "src",
    "brand-sheet.html",
    "icons"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "render-icon": "node scripts/render-icon.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
