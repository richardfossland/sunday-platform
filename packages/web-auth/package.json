{
  "name": "@sunday/web-auth",
  "version": "0.1.0",
  "description": "Shared Next.js auth for the Sunday suite: @supabase/ssr server/browser clients, middleware session gate, hardened OAuth callback, and server-side guards (cross-project-aware Sunday Account SSO).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sunday/auth-client": "workspace:*",
    "jose": "^5.9.0"
  },
  "peerDependencies": {
    "@supabase/ssr": ">=0.5.0",
    "next": ">=14",
    "react": ">=18"
  },
  "devDependencies": {
    "@supabase/ssr": "^0.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
